/middleware.ts                  @haveebot @nickbmerrill-collab
/auth.ts                        @haveebot @nickbmerrill-collab
/auth.config.ts                 @haveebot @nickbmerrill-collab

# Auth / DB / messaging / payment integrations
/lib/auth/                      @haveebot @nickbmerrill-collab
/lib/db/                        @haveebot @nickbmerrill-collab
/lib/stripe/                    @haveebot @nickbmerrill-collab
/lib/twilio/                    @haveebot @nickbmerrill-collab
/lib/resend/                    @haveebot @nickbmerrill-collab
/db/                            @haveebot @nickbmerrill-collab
/drizzle/                       @haveebot @nickbmerrill-collab

# ──────────────────────────────────────────────────────────────────
# Build / deps / config — operator review required
# ──────────────────────────────────────────────────────────────────
/package.json                   @haveebot @nickbmerrill-collab
/package-lock.json              @haveebot @nickbmerrill-collab
/pnpm-lock.yaml                 @haveebot @nickbmerrill-collab
/next.config.*                  @haveebot @nickbmerrill-collab
/vercel.json                    @haveebot @nickbmerrill-collab
/tsconfig.json                  @haveebot @nickbmerrill-collab
/drizzle.config.*               @haveebot @nickbmerrill-collab

# Env (should already be gitignored — defense-in-depth)
